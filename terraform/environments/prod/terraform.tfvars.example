# Copy this file to terraform.tfvars and fill in the values before running terraform apply.
# terraform.tfvars is in .gitignore — never commit it with real values.

project_name       = "crudapp"
environment        = "prod"
location           = "koreacentral"
db_admin_username  = "mysqladmin"
db_name            = "trainee_db"
backend_image_name = "backend-app"
backend_image_tag  = "v1.0.0"   # Must NOT be 'latest' for prod
enable_waf         = true
